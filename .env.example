# Spotify OAuth app credentials
# Create an app at https://developer.spotify.com/dashboard/
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# App URLs
# For local development, set the Spotify redirect URI to:
# http://127.0.0.1:3000/api/auth/callback/spotify
APP_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000

# Production example:
# APP_URL=https://playlist.yourdomain.com
# NEXTAUTH_URL=https://playlist.yourdomain.com

# Auth.js session secret
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_a_long_random_secret

# setlist.fm API
# Request an API key at https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=your_setlistfm_api_key
